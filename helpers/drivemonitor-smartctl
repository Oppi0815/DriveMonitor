#!/usr/bin/env python3
from __future__ import annotations
import os
import re
import shutil
import sys

ALLOWED_DEVICE = re.compile(r"^/dev/(sd[a-z]+|nvme\d+n\d+)$")
ALLOWED_PREFIX = ["-a", "-j"]
ALLOWED_TYPES = {
    "sat", "sat,12", "sat,16", "scsi", "usbjmicron", "usbjmicron,x",
    "usbsunplus", "sntjmicron", "sntrealtek"
}

def fail(message: str) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(2)

args = sys.argv[1:]
if len(args) not in (3, 5) or args[:2] != ALLOWED_PREFIX:
    fail("Ungültiger DriveMonitor-Aufruf.")
if len(args) == 5:
    if args[2] != "-d" or args[3] not in ALLOWED_TYPES:
        fail("Nicht erlaubter Gerätetyp.")
device = args[-1]
if not ALLOWED_DEVICE.fullmatch(device):
    fail("Nicht erlaubtes Gerät.")
smartctl = shutil.which("smartctl") or "/usr/sbin/smartctl"
if not os.path.exists(smartctl):
    fail("smartctl wurde nicht gefunden.")
os.execv(smartctl, [smartctl, *args])
